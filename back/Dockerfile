# Le point de depart de la création de l'image FROM, appel 
# une image déjà créer avec maven:3.6.3 déjà dans l'image pour l'utiliser après:
FROM maven:3.6.3-jdk-11-slim AS buildAppJava

# Création du dossier /workspace dans l'image Docker pour travailler dedans après:
RUN mkdir -p /workspace

# On se place dans ce dossier dans l'image
WORKDIR /workspace


# Puis on copie dans le /workspace le fichier pom.xml et le dossier src (qui contiennent les dependances + le code de l'app)
COPY pom.xml /workspace
COPY src /workspace/src

# Puis on compile l'app java en .jar via run mvn clean package
RUN mvn -B -f pom.xml clean package -DskipTests

# Point de départ d'une nouvelle image qui contient déjà un mini linux simplifié (-jammy) 
# ainsi qu'un JDK avec java 11 + jvm (eclipse-temurin:11-jdk).
FROM eclipse-temurin:11-jdk-jammy 

# Puis copie le *.jar de l'étape builAppJava d'avant, sous le nom app.jar dans le dossier racine / de cette nouvelle image 
COPY --from=buildAppJava /workspace/target/*.jar app.jar

# Informe Docker que cette app est accéssible sur le port 8080 du conteneur (dans le mini linux du container)
EXPOSE 8080


ENTRYPOINT ["java", "-jar","app.jar"]























































































































































































































































































































































































































